# sdet-brain-win — environment template. Copy to `.env` and fill in real values.
# All variables map 1:1 to fields on `sdet_brain.config.Settings`.

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=sdet_brand_v1

# --- Embeddings ---
# Primary provider: "ollama" (local CUDA, default) or "gemini" (cloud fallback).
EMBEDDING_PROVIDER=ollama

# Ollama (default provider on Windows fork)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_BATCH_SIZE=16
OLLAMA_TIMEOUT_S=60

# Gemini (cloud fallback)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_VECTOR_SIZE=1024

# --- Server ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
MCP_SSE_PORT=8081
LOG_LEVEL=INFO

# --- Ingestion ---
CHUNK_TARGET_CHARS=800
CHUNK_OVERLAP_RATIO=0.15
EMBED_BATCH_SIZE=32
WATCH_PATHS=
WATCHER_DEBOUNCE_MS=300

# --- Reranking ---
# Cross-encoder reranks an over-fetched candidate set so accuracy benefits
# from a slow precise model without paying its cost on the whole index.
# Reranker stays on CPU via fastembed — no VRAM impact.
RERANK_ENABLED=true
RERANK_MODEL=jinaai/jina-reranker-v2-base-multilingual
RERANK_TOP_K_RETRIEVE=30
RERANK_TOP_K_RETURN=5

# --- OCR (image / PDF ingestion) ---
# Ollama vision model for OCR. deepseek-ocr is the 4 GB-VRAM-friendly default;
# set a fallback for boxes with headroom (e.g. a larger qwen2.5-vl tag).
OCR_PROVIDER=ollama
OCR_OLLAMA_PRIMARY_MODEL=deepseek-ocr
OCR_OLLAMA_FALLBACK_MODEL=
OCR_TIMEOUT_SECONDS=120
OCR_MAX_IMAGE_DIM=1600
OCR_MAX_IMAGE_BYTES=20000000
OCR_MAX_PDF_PAGES=20
OCR_KEEP_ALIVE=5m
OCR_QUALITY_MIN_CHARS=50
OCR_PII_SCRUB=false
# Prompt overrides (OCR_GROUNDING_PROMPT / OCR_GENERAL_PROMPT) exist on
# Settings too; leave unset to use the built-in defaults.

# --- Corpus source paths (per source_type) ---
# Use COMMA `,` as the separator (parse_path_list splits on comma on all
# platforms). Each is a list of absolute directories. Empty means "no roots
# for that source_type" - files outside all roots fall back to
# source_type=unknown. Windows paths use backslash, no quotes needed:
#   DRAFTS_PATHS=C:\Users\you\dev\my-brand-drafts
#   DRAFTS_PATHS=C:\a\drafts,C:\b\more-drafts   # two roots, comma-separated
PROJECT_KNOWLEDGE_PATHS=
DRAFTS_PATHS=
ARTICLES_PATHS=
SPRINT_REPORTS_PATHS=
BRIEF_PATHS=

# --- daily.py automation ---
# scripts/daily.py reads these on top of the standard server config.
INGEST_MIN_GB=8
SDET_BRAIN_SERVER_URL=http://localhost:8080
QDRANT_SNAPSHOT_ENABLED=false
RESPECT_USER_IDLE=true
# Path to log file. Leave unset to default to %LOCALAPPDATA%\sdet-brain\daily.log
# DAILY_LOG=
