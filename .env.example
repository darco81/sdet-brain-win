# SDET Brain - environment template. Copy to `.env` and fill in real values.
# All variables map 1:1 to fields on `sdet_brain.config.Settings`.

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# Leave empty for local dev; required on production VPS (Tier 3).
QDRANT_API_KEY=
COLLECTION_NAME=sdet_brand_v1

# --- Embeddings ---
# Primary provider: "mlx" (local M-series) or "gemini" (cloud fallback).
EMBEDDING_PROVIDER=mlx
MLX_MODEL=Qwen/Qwen3-Embedding-0.6B
MLX_VECTOR_SIZE=1024
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_VECTOR_SIZE=768

# --- Server ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
MCP_SSE_PORT=8081
LOG_LEVEL=INFO

# --- Ingestion ---
CHUNK_TARGET_CHARS=800
CHUNK_OVERLAP_RATIO=0.15
EMBED_BATCH_SIZE=32
# Comma-separated absolute paths the watcher monitors (T1-08).
WATCH_PATHS=
WATCHER_DEBOUNCE_MS=300

# --- Brand corpus source paths (per source_type) ---
# Each is a comma-separated list of absolute directories. Empty means
# "no roots for this source_type" - files outside all roots fall back
# to source_type=unknown. Leaving these empty on a local M4 Pro keeps
# the in-code defaults (Dariusz's setup); the values below are
# typically only set on the VPS / containers (T3-03).
PROJECT_KNOWLEDGE_PATHS=
DRAFTS_PATHS=
ARTICLES_PATHS=
SPRINT_REPORTS_PATHS=
BRIEF_PATHS=
