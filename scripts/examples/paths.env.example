# Save as ~/.config/sdet-brain/paths.env (chmod 600).
# Each var is a comma-separated list of absolute directories. Empty
# means "no roots registered for that source_type" (chunks tag as
# `unknown`). These mirror the env vars the server's own Settings
# class already reads - daily.sh just propagates them into the
# `sdet-brain-cli` invocation.

DRAFTS_PATHS=/Users/you/dev/brand-drafts
ARTICLES_PATHS=/Users/you/dev/published-articles
PROJECT_KNOWLEDGE_PATHS=/Users/you/dev/strategy,/Users/you/dev/methodology
SPRINT_REPORTS_PATHS=
BRIEF_PATHS=
