# Save as ~/.config/sdet-brain/discord.env (chmod 600).
# Optional - when present, digest.py POSTs an embed to this webhook
# after each successful run. Leave the file out (or unset the var)
# to skip the Discord step.
#
# Cloudflare blocks Python's default User-Agent with a 1010 response;
# digest.py sends a `User-Agent: sdet-brain-digest/...` header, which
# is enough to pass.

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE/WITH_YOUR_WEBHOOK
